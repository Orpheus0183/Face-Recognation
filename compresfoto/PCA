import gradio as gr
import numpy as np
from sklearn.decomposition import PCA
import math


def calculate_psnr(original, compressed):
    mse = np.mean((original.astype(np.float64) - compressed.astype(np.float64)) ** 2)
    if mse == 0:
        return float('inf')
    max_pixel = 255.0
    return 20 * math.log10(max_pixel / math.sqrt(mse))


def get_pca_size_kb(h, w, k, n_channels):
    """
    Ukuran data PCA (float32, 4 byte per nilai):
      - Scores       : h * k  per channel
      - Components   : k * w  per channel
      - Mean vector  : w      per channel
    Total = n_channels * (h*k + k*w + w) nilai float32
    """
    pca_floats = n_channels * (h * k + k * w + w)
    return (pca_floats * 4) / 1024  # 4 bytes per float32


def get_original_size_kb(h, w, n_channels):
    """
    Ukuran gambar asli (uint8, 1 byte per nilai):
      Total = h * w * n_channels byte
    """
    return (h * w * n_channels * 1) / 1024  


def process_pca(input_img, k_value, is_gray=False):
    if input_img is None:
        return None, "Tidak ada gambar yang diupload."

  
    if is_gray and len(input_img.shape) == 3:
        input_img = np.dot(input_img[..., :3], [0.299, 0.587, 0.114]).astype(np.uint8)

    original_shape = input_img.shape
    h, w = original_shape[0], original_shape[1]
    n_channels = 1 if len(original_shape) == 2 or is_gray else 3

    max_k = min(h, w)
    k = min(int(k_value), max_k)

    k_warning = ""
    if k < int(k_value):
        k_warning = f" K dipotong dari {int(k_value)} → {k} (batas maks untuk gambar ini)\n\n"

    # --- PCA per channel ---
    if n_channels == 3:
        channels = [input_img[:, :, i] for i in range(3)]
        compressed_channels = []
        variances = []
        for ch in channels:
            pca = PCA(n_components=k)
            transformed = pca.fit_transform(ch.astype(np.float64))
            reconstructed = pca.inverse_transform(transformed)
            compressed_channels.append(reconstructed)
            variances.append(np.sum(pca.explained_variance_ratio_))
        img_reconstructed = np.stack(compressed_channels, axis=2)
        avg_variance = (sum(variances) / 3) * 100
    else:
        pca = PCA(n_components=k)
        transformed = pca.fit_transform(input_img.astype(np.float64))
        img_reconstructed = pca.inverse_transform(transformed)
        avg_variance = np.sum(pca.explained_variance_ratio_) * 100

    img_final = np.clip(img_reconstructed, 0, 255).astype(np.uint8)
    psnr_value = calculate_psnr(input_img, img_final)

    
    original_kb = get_original_size_kb(h, w, n_channels)   
    compressed_kb = get_pca_size_kb(h, w, k, n_channels)   

    size_ratio = original_kb / compressed_kb if compressed_kb > 0 else 0

   
    original_params = h * w * n_channels                    
    pca_params = n_channels * (k * w + h * k + w)           

  
    parameter_ratio = original_params / pca_params if pca_params > 0 else 0

    if psnr_value == float('inf'):
        kategori = "Identik dengan asli"
    elif psnr_value > 40:
        kategori = "Sangat Bagus (Hampir tak terlihat bedanya)"
    elif psnr_value > 30:
        kategori = "Bagus (Distorsi rendah)"
    elif psnr_value >= 20:
        kategori = "Cukup (Ada sedikit noise)"
    else:
        kategori = "Jelek (Distorsi tinggi/buruk)"

    analysis_text = (
        f"{k_warning}"
        f"--- KUALITAS ({'GRAYSCALE' if n_channels == 1 else 'BERWARNA'}) ---\n"
        f"Nilai K yang digunakan  : {k} / {max_k} (maks)\n"
        f"Informasi dipertahankan : {avg_variance:.2f}%\n"
        f"Kualitas (PSNR)         : {psnr_value:.2f} dB\n"
        f"Status Kualitas         : {kategori}\n\n"
        f"--- UKURAN PENYIMPANAN  ---\n"
        f"  Original  : uint8  → {original_kb:.2f} KB\n"
        f"  PCA       : float32 → {compressed_kb:.2f} KB\n"
        f"  Rasio Ukuran   : {size_ratio:.2f}x\n\n"
        f"--- JUMLAH PARAMETER  ---\n"
        f"  Parameter Asli       : {original_params:,} nilai\n"
        f"  Parameter PCA        : {pca_params:,} nilai\n"
        f"  Rasio Parameter      : {parameter_ratio:.2f}x\n"
        f"  Rasio ukuran nyata = {size_ratio:.2f}"
    )

    return img_final, analysis_text


def compress_color(img, k):
    return process_pca(img, k, is_gray=False)


def compress_gray(img, k):
    return process_pca(img, k, is_gray=True)


with gr.Blocks(title="Kompresi PCA") as demo:
    gr.Markdown("# Kompresi Gambar Menggunakan PCA")
    gr.Markdown("Pilih tab di bawah untuk mengompres foto berwarna atau otomatis mengubahnya ke grayscale.")

    with gr.Tab("Foto Berwarna"):
        with gr.Row():
            with gr.Column():
                input_color = gr.Image(label="Upload Foto Berwarna", type="numpy")
                slider_color = gr.Slider(1, 500, value=50, step=1, label="Nilai K")
                btn_color = gr.Button("Kompres Berwarna")
            with gr.Column():
                output_color = gr.Image(label="Hasil PCA (Berwarna)")
                analysis_color = gr.Textbox(label="Analisis Hasil", lines=16)

        btn_color.click(compress_color, inputs=[input_color, slider_color], outputs=[output_color, analysis_color])

    with gr.Tab("Foto Grayscale"):
        with gr.Row():
            with gr.Column():
                input_gray = gr.Image(label="Upload Foto (Akan di-Grayscale)", type="numpy")
                slider_gray = gr.Slider(1, 500, value=50, step=1, label="Nilai K")
                btn_gray = gr.Button("Kompres Grayscale")
            with gr.Column():
                output_gray = gr.Image(label="Hasil PCA (Grayscale)", image_mode="L")
                analysis_gray = gr.Textbox(label="Analisis Hasil", lines=16)

        btn_gray.click(compress_gray, inputs=[input_gray, slider_gray], outputs=[output_gray, analysis_gray])

if __name__ == "__main__":
    demo.launch()
